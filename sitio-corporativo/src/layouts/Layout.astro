---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Cantera Estudio — Arquitectura & Construcción',
  description = 'Estudio de arquitectura y construcción. Diseño, obra y supervisión de proyectos residenciales, corporativos e institucionales.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="theme-color" content="#f7f3e9" />
  </head>
  <body class="antialiased">
    <slot />
    <script>
      import '../scripts/reveal.ts';
    </script>
  </body>
</html>
