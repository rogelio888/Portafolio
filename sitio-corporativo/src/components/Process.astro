---
const steps = [
  { title: 'Consulta', desc: 'Visita al terreno y presupuesto referencial en 72 horas.' },
  { title: 'Diseño', desc: 'Anteproyecto y planos ejecutivos listos para aprobación municipal.' },
  { title: 'Construcción', desc: 'Obra ejecutada por cuadrilla propia, con reportes semanales.' },
  { title: 'Entrega', desc: 'Inspección final, planos as-built y garantía de cinco años.' }
];
---

<section id="proceso" class="max-w-7xl mx-auto px-5 sm:px-8 py-20 sm:py-28 border-b border-ink/12">
  <h2 class="font-display text-3xl sm:text-4xl text-ink mb-16" data-reveal>Cómo trabajamos</h2>

  <div class="relative">
    <div class="hidden sm:block absolute top-[7px] left-0 right-0 h-px bg-ink/15"></div>
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-10 sm:gap-6">
      {steps.map((step, i) => (
        <div class="relative" data-reveal data-reveal-delay={i * 100}>
          <div class="hidden sm:flex w-3.5 h-3.5 rounded-full bg-clay relative z-10 mb-6"></div>
          <span class="sm:hidden text-xs font-mono-label text-clay">0{i + 1}</span>
          <h3 class="font-display text-xl text-ink mt-2 sm:mt-0 mb-2">{step.title}</h3>
          <p class="text-ink-soft text-sm leading-relaxed max-w-[220px]">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
